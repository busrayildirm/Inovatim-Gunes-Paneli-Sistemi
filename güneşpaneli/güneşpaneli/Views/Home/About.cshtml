@{
    ViewData["Title"] = "Hakkımızda";
}

<section style="padding: 60px 20px; background-color: #e6f4ea; border-radius: 12px; text-align:center;">
    <h1 style="font-size:2.5rem; color:#2f7a2f;">Hakkımızda</h1>
    <p style="max-width:700px; margin:auto; font-size:1.1rem; color:#333; margin-top:20px;">
        Biz, inşaat atıklarını yenilenebilir enerji üretiminde kullanarak çevre dostu çözümler sunan bir girişimiz.
        Amacımız, sürdürülebilir enerji ve temiz bir gelecek için yenilikçi projeler geliştirmektir.
    </p>
</section>

<!-- Proje Süreci Kartları -->
<div class="container my-5">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <img src="~/images/panel1.jpg" class="card-img-top" alt="Atık Toplama">
                <div class="card-body">
                    <h5 class="card-title">Atık Toplama</h5>
                    <p class="card-text">İnşaat sahalarından toplanan atık malzemeler ayrıştırılır ve geri dönüşüme hazırlanır.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm">
                <img src="~/images/panel2.jpg" class="card-img-top" alt="Üretim">
                <div class="card-body">
                    <h5 class="card-title">Panel Üretimi</h5>
                    <p class="card-text">Toplanan malzemeler, modern üretim tesislerinde güneş paneline dönüştürülür.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm">
                <img src="~/images/hero.jpg" class="card-img-top" alt="Kurulum ve Kullanım">
                <div class="card-body">
                    <h5 class="card-title">Kurulum & Kullanım</h5>
                    <p class="card-text">Üretilen güneş panelleri, konut ve sanayi alanlarında temiz enerji kaynağı olarak kullanılır.</p>
                </div>
            </div>
        </div>
    </div>
</div>
