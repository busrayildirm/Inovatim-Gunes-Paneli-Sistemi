@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="hero">
    <h1>Solar Mod - İnşaat Atıklarından Güneş Paneli</h1>
    <p>Çevre dostu enerji üretimi için sürdürülebilir çözümler</p>
    <a href="/Home/Calculator" class="btn btn-hero mt-3">Enerji Hesapla</a>
</div>

<div class="row text-center mt-5">
    <div class="col-md-4">
        <div class="card p-3">
            <img src="/images/panel1.jpg" class="card-img-top" alt="Panel 1">
            <div class="card-body">
                <h5 class="card-title">Yenilenebilir Enerji</h5>
                <p class="card-text">İnşaat atıklarından üretilen güneş panelleri ile temiz enerji.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-3">
            <img src="/images/panel2.jpg" class="card-img-top" alt="Panel 2">
            <div class="card-body">
                <h5 class="card-title">Ekonomik Çözümler</h5>
                <p class="card-text">Düşük maliyetle enerji tasarrufu sağlayın.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-3">
            <img src="/images/panel3.jpg" class="card-img-top" alt="Panel 3">
            <div class="card-body">
                <h5 class="card-title">Çevre Dostu</h5>
                <p class="card-text">Sürdürülebilir ve çevreye zarar vermeyen teknoloji.</p>
            </div>
        </div>
    </div>
</div>

